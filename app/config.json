{
  "app_info": {
    "theme": "one_dark",
    "version": "1.0.22",
    "build": "223"
  },
  "pre_git": {
    "enabled": true,
    "commit_message": "pre-release cleanup",
    "steps": {
      "git_commit_pre": false
    }
  },
  "common": {
    "enabled": true,
    "pub_mode": "pub get",
    "steps": {
      "clean": false,
      "pub_get": false
    }
  },
  "post_git": {
    "enabled": true,
    "commit_message": "v{version} ({build})",
    "steps": {
      "git_pull": false,
      "git_commit_rel": false,
      "git_push": false
    }
  },
  "android": {
    "enabled": true,
    "shorebird": false,
    "shorebird_mode": "Release",
    "steps": {
      "build_apk": false
    }
  },
  "ios": {
    "enabled": true,
    "shorebird": false,
    "shorebird_mode": "Release",
    "steps": {
      "pod_install": false,
      "build_ipa": false,
      "appstore_upload": false
    }
  },
  "post_build": {
    "enabled": true,
    "power_mode": "Sleep",
    "quit_after_power": false,
    "steps": {
      "open_folders": false,
      "drive_upload": false,
      "shutdown": false
    }
  }
}
