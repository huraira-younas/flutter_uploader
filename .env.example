# Flutter project this app runs pipelines against (directory with pubspec.yaml)
FLUTTER_PROJECT_ROOT=/absolute/path/to/flutter_app

# Google Drive (required for upload): path to OAuth client-secret JSON
GOOGLE_DRIVE_CREDENTIALS_JSON=path/to/your-client-secret.json

# Optional: where to save OAuth token (default: gdrive_token.json beside client secret)
# GOOGLE_DRIVE_TOKEN_JSON=

# Optional: parent folder ID to upload into
GOOGLE_DRIVE_FOLDER_ID=

GMAIL_APP_PASSWORD=your_app_password
GMAIL_USER=your_email@gmail.com

# App Store Connect (required for iOS upload via xcrun altool)
APP_STORE_ISSUER_ID=YOUR_ISSUER_ID_HERE
APP_STORE_API_KEY=YOUR_KEY_ID_HERE
